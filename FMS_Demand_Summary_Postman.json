{
  "info": {
    "_postman_id": "fms-demand-summary-tests",
    "name": "FMS Demand Summary Validation Tests",
    "description": "Postman collection for testing the Demand Summary endpoint with various parameter combinations and edge cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Success Scenarios",
      "item": [
        {
          "name": "Valid Request - Federal",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/demands/summary?fertilizerTypeId={{validFertilizerTypeId}}&adminId={{validFederalId}}&userLevel=FEDERAL",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "demands",
                "summary"
              ],
              "query": [
                {
                  "key": "fertilizerTypeId",
                  "value": "{{validFertilizerTypeId}}"
                },
                {
                  "key": "adminId",
                  "value": "{{validFederalId}}"
                },
                {
                  "key": "userLevel",
                  "value": "FEDERAL"
                }
              ]
            }
          }
        },
        {
          "name": "Valid Request - Region",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/demands/summary?fertilizerTypeId={{validFertilizerTypeId}}&adminId={{validRegionId}}&userLevel=REGION",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "demands",
                "summary"
              ],
              "query": [
                {
                  "key": "fertilizerTypeId",
                  "value": "{{validFertilizerTypeId}}"
                },
                {
                  "key": "adminId",
                  "value": "{{validRegionId}}"
                },
                {
                  "key": "userLevel",
                  "value": "REGION"
                }
              ]
            }
          }
        }
      ]
    },
