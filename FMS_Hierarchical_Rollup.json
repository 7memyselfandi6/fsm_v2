  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
          "pm.test(\"Valid JSON\", function () { pm.response.to.be.json; });"
        ]
      }
    }
