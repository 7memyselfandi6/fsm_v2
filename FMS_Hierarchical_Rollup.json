{
  "info": {
    "_postman_id": "fms-hierarchical-analytics",
    "name": "FMS Hierarchical Analytics",
    "description": "Specific endpoints for Federal, Region, Zone, and Woreda summary and drill-down analytics. No required query parameters (productionSeason is now optional).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Federal",
      "item": [
        {
          "name": "Federal Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/fertilizer-demand/federal",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "fertilizer-demand",
                "federal"
              ]
            }
          }
        },
        {
          "name": "Federal Drill-Down",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/fertilizer-demand/federal/:fertilizerType",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "fertilizer-demand",
                "federal",
                ":fertilizerType"
              ],
              "variable": [
                {
                  "key": "fertilizerType",
                  "value": "UREA",
                  "description": "e.g., UREA or DAP"
                }
              ]
            }
          }
        }
      ]
    },
    {
