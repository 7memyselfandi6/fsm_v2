generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Federal {
  id        String   @id @default(uuid())
  name      String   @unique
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String?       @unique
  status       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  regionalFlag RegionalFlag?
  unions       Union[]
  users        User[]
  zones        Zone[]
  warehouses   Warehouse[]
  subsidies    FertilizerSubsidy[]
  locks        LockHistory[]
}

model Zone {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  unions    Union[]
  users     User[]
  woredas   Woreda[]
  region    Region   @relation(fields: [regionId], references: [id])

  @@unique([name, regionId])
  @@index([regionId])
}

model Woreda {
  id        String   @id @default(uuid())
  name      String
  zoneId    String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  kebeles   Kebele[]
  users     User[]
  zone      Zone     @relation(fields: [zoneId], references: [id])

  @@unique([name, zoneId])
  @@index([zoneId])
}

model Kebele {
  id        String   @id @default(uuid())
  name      String
  woredaId  String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farmers   Farmer[]
  woreda    Woreda   @relation(fields: [woredaId], references: [id])
  pcs       PC[]
  users     User[]
  sections  Section[]

  @@unique([name, woredaId])
  @@index([woredaId])
}

model Section {
  id        String   @id @default(uuid())
  name      String
  kebeleId  String
  kebele    Kebele   @relation(fields: [kebeleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, kebeleId])
  @@index([kebeleId])
}

model RegionalFlag {
  id        String   @id @default(uuid())
  name      String
  category  String
  imageUrl  String
  regionId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  region    Region   @relation(fields: [regionId], references: [id])
}

model FederalFlag {
  id        String   @id @default(uuid())
  name      String
  category  String
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                String            @id @default(uuid())
  fullName          String
  username          String            @unique
  email             String            @unique
  phoneNumber       String            @unique
  password          String
  profilePictureUrl String?
  kebeleId          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  moaDesk           String?
  moaLeadExecutive  MoaLeadExecutive?
  moaPosition       MoaPosition?
  moaRole           MoaRole?
  moaSector         MoaSector?
  pcId              String?
  regionId          String?
  role              Role
  unionId           String?
  woredaId          String?
  zoneId            String?
  farmerId          String?           @unique
  salesAsAccountant FertilizerSale[]  @relation("Accountant")
  salesAsStoreman   FertilizerSale[]  @relation("Storeman")
  farmerProfile     Farmer?           @relation(fields: [farmerId], references: [id])
  kebele            Kebele?           @relation(fields: [kebeleId], references: [id])
  pc                PC?               @relation(fields: [pcId], references: [id])
  region            Region?           @relation(fields: [regionId], references: [id])
  union             Union?            @relation(fields: [unionId], references: [id])
  woreda            Woreda?           @relation(fields: [woredaId], references: [id])
  zone              Zone?             @relation(fields: [zoneId], references: [id])
  lockOverrides     LockHistory[]     @relation("LockOverrideBy")
}

model Union {
  id           String        @id @default(uuid())
  name         String        @unique
  regionId     String
  zoneId       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  destinations Destination[]
  region       Region        @relation(fields: [regionId], references: [id])
  zone         Zone?         @relation(fields: [zoneId], references: [id])
  users        User[]

  @@index([regionId])
  @@index([zoneId])
}

model Destination {
  id            String        @id @default(uuid())
  name          String
  unionId       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  union         Union         @relation(fields: [unionId], references: [id])
  lotDispatches LotDispatch[]
  pcs           PC[]

  @@index([unionId])
}

model PC {
  id            String           @id @default(uuid())
  name          String
  kebeleId      String
  destinationId String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sales         FertilizerSale[]
  destination   Destination      @relation(fields: [destinationId], references: [id])
  kebele        Kebele           @relation(fields: [kebeleId], references: [id])
  inventory     PCInventory[]
  users         User[]

  @@index([kebeleId])
  @@index([destinationId])
}

model Farmer {
  id                 String           @id @default(uuid())
  uniqueFarmerId     String?          @unique
  fullName           String
  gender             String
  phoneNumber        String           @unique
  address            String
  farmAreaHectares   Float
  photoUrl           String?
  landCertificateUrl String?
  kebeleId           String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  kebele             Kebele           @relation(fields: [kebeleId], references: [id])
  demands            FarmerDemand[]
  sales              FertilizerSale[]
  user               User?

  @@index([kebeleId])
}

model Season {
  id        String         @id @default(uuid())
  name      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  demands   FarmerDemand[]
}

model CropCategory {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cropTypes CropType[]
}

model CropType {
  id         String         @id @default(uuid())
  name       String
  categoryId String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  category   CropCategory   @relation(fields: [categoryId], references: [id])
  demands    FarmerDemand[]
  rates      CropFertilizerRate[]

  @@unique([name, categoryId])
}

model FertilizerType {
  id           String           @id @default(uuid())
  name         String           @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  demands      FarmerDemand[]
  sales        FertilizerSale[]
  inventory    PCInventory[]
  shippingLots ShippingLot[]
  subsidies    FertilizerSubsidy[]
}

model FarmerDemand {
  id                     String         @id @default(uuid())
  farmerId               String
  seasonId               String
  cropTypeId             String
  fertilizerTypeId       String
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  kebeleAdjustedQuantity Float?
  lockedAtLevel          LockingLevel   @default(NONE)
  moaAdjustedQuantity    Float?
  originalQuantity       Float
  regionAdjustedQuantity Float?
  woredaAdjustedQuantity Float?
  zoneAdjustedQuantity   Float?
  status                 DemandStatus   @default(PENDING)
  cropType               CropType       @relation(fields: [cropTypeId], references: [id])
  farmer                 Farmer         @relation(fields: [farmerId], references: [id])
  fertilizerType         FertilizerType @relation(fields: [fertilizerTypeId], references: [id])
  season                 Season         @relation(fields: [seasonId], references: [id])

  @@index([farmerId])
  @@index([seasonId])
  @@index([fertilizerTypeId])
}

model ShippingLot {
  id               String         @id @default(uuid())
  lotNumber        Int            @unique
  fertilizerTypeId String
  totalQuantity    Float
  ureaAmount       Float?         @default(0)
  dapAmount        Float?         @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  dispatches       LotDispatch[]
  fertilizerType   FertilizerType @relation(fields: [fertilizerTypeId], references: [id])
}

model LotDispatch {
  id            String      @id @default(uuid())
  lotId         String
  destinationId String
  quantity      Float
  dispatchedAt  DateTime    @default(now())
  destination   Destination @relation(fields: [destinationId], references: [id])
  lot           ShippingLot @relation(fields: [lotId], references: [id])
}

model PCInventory {
  id               String         @id @default(uuid())
  pcId             String
  fertilizerTypeId String
  quantity         Float          @default(0)
  updatedAt        DateTime       @updatedAt
  fertilizerType   FertilizerType @relation(fields: [fertilizerTypeId], references: [id])
  pc               PC             @relation(fields: [pcId], references: [id])

  @@unique([pcId, fertilizerTypeId])
}

model FertilizerSale {
  id               String         @id @default(uuid())
  farmerId         String
  pcId             String
  fertilizerTypeId String
  quantity         Float
  totalPrice       Float
  paymentMethod    PaymentMethod
  status           SaleStatus     @default(PAYMENT_RECEIVED)
  accountantId     String
  storemanId       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  accountant       User           @relation("Accountant", fields: [accountantId], references: [id])
  farmer           Farmer         @relation(fields: [farmerId], references: [id])
  fertilizerType   FertilizerType @relation(fields: [fertilizerTypeId], references: [id])
  pc               PC             @relation(fields: [pcId], references: [id])
  storeman         User?          @relation("Storeman", fields: [storemanId], references: [id])
}

model Warehouse {
  id            String   @id @default(uuid())
  center        String
  destinationId String
  regionId      String
  zoneId        String
  woredaId      String
  town          String
  year          Int
  isOwn         Boolean  @default(true)
  isRental      Boolean  @default(false)
  capacity      Float
  storeman      String
  sex           String
  education     String
  mobile        String
  hasOffice     Boolean  @default(false)
  hasComputer   Boolean  @default(false)
  hasSmartphone Boolean  @default(false)
  hasWifi       Boolean  @default(false)
  hasElectric   Boolean  @default(false)
  networkType   String?  // 3G, 4G, 5G
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  region        Region   @relation(fields: [regionId], references: [id])
}

model FertilizerSubsidy {
  id               String         @id @default(uuid())
  eid              String         @unique
  year             Int
  regionId         String
  fertilizerTypeId String
  amountMT         Float
  amountQT         Float
  priceBefore      Float
  priceAfter       Float
  subsidyAmount    Float
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  region           Region         @relation(fields: [regionId], references: [id])
  fertilizerType   FertilizerType @relation(fields: [fertilizerTypeId], references: [id])
}

model CropFertilizerRate {
  id         Int      @id @default(autoincrement())
  cropId     String
  highUrea   Float
  highDap    Float
  mediumUrea Float
  mediumDap  Float
  lowUrea    Float
  lowDap     Float
  isLocked   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  crop       CropType @relation(fields: [cropId], references: [id])
}

model LockHistory {
  id            String       @id @default(uuid())
  level         LockingLevel
  regionId      String?
  isGlobal      Boolean      @default(false)
  isLocked      Boolean      @default(true)
  reason        String?
  timestamp     DateTime     @default(now())
  overriddenById String?
  region        Region?      @relation(fields: [regionId], references: [id])
  overriddenBy  User?        @relation("LockOverrideBy", fields: [overriddenById], references: [id])
}

enum Role {
  SUPER_ADMIN
  MOA_EXPERT
  MOA_MANAGER
  REGION_EXPERT
  REGION_MANAGER
  ZONE_EXPERT
  ZONE_MANAGER
  WOREDA_EXPERT
  WOREDA_MANAGER
  KEBELE_DA
  KEBELE_MANAGER
  PC_ACCOUNTANT
  PC_STOREMAN
  UNION_MEMBER
  FARMER
}

enum MoaPosition {
  MINISTER
  STATE_MINISTER
  LEAD_EXECUTIVE_MINISTER
  DESK_HEAD
  EXPERT
}

enum MoaRole {
  DATA_LOGGER
  DATA
}

enum MoaSector {
  INPUT_AND_INVESTMENT
  AGRICULTURE_AND_HORTICULTURE_INVESTMENT
}

enum MoaLeadExecutive {
  INPUT_LE
  CROP_LE
  HORTICULTURE_LE
  AGRICULTURE_AND_INVESTMENT_LE
  URBAN_LE
  COTTON_LE
}

enum DemandStatus {
  PENDING
  APPROVED
  LOCKED
}

enum LockingLevel {
  NONE
  KEBELE
  WOREDA
  ZONE
  REGION
  MOA
}

enum PaymentMethod {
  CASH
  TELEBIRR
  CBE
  MOBILE_BANKING
}

enum SaleStatus {
  PAYMENT_RECEIVED
  DELIVERED
}
