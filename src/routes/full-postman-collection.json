          }
        },
        {
          "name": "Region Detail List",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/region/detail-list?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "region", "detail-list"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Region Adjustment Table",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/region/adjustment-table", "host": ["{{baseUrl}}"], "path": ["api", "region", "adjustment-table"] }
          }
        },
        {
          "name": "Region Lock/Unlock",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zoneId\": \"ZONE_UUID\",\n  \"lock\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/region/lock", "host": ["{{baseUrl}}"], "path": ["api", "region", "lock"] }
          }
        },
        {
          "name": "Region Submit Adjustment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fertilizerTypeId\": \"FERT_UUID\",\n  \"adjustments\": [\n    { \"zoneId\": \"ZONE_UUID\", \"quantity\": 500 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/region/adjust", "host": ["{{baseUrl}}"], "path": ["api", "region", "adjust"] }
          }
        }
