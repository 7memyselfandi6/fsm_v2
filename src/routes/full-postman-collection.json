{
  "info": {
    "name": "Ethiopian Fertilizer Digital Tracking System - Full API",
    "description": "Comprehensive Postman collection for the entire FMS Backend, including all hierarchical levels (Federal, Region, Zone, Woreda, Kebele) and operational modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01. Authentication",
      "item": [
        {
          "name": "Login (PhoneNumber)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"0912345678\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Register (Admin Only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "multipart/form-data" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullName", "value": "Abebe Balcha", "type": "text" },
                { "key": "username", "value": "abebe123", "type": "text" },
                { "key": "email", "value": "abebe@example.com", "type": "text" },
                { "key": "phoneNumber", "value": "0911223344", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "role", "value": "REGION_MANAGER", "type": "text" },
                { "key": "regionId", "value": "REGION_UUID", "type": "text" },
                { "key": "profilePicture", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "02. Federal (MoA) Module",
      "item": [
        {
          "name": "Federal Dashboard",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/federal/dashboard?seasonName=Meher", "host": ["{{baseUrl}}"], "path": ["api", "federal", "dashboard"], "query": [{ "key": "seasonName", "value": "Meher" }] }
          }
        },
        {
          "name": "Master Data (Hierarchy Tree)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/federal/master-data", "host": ["{{baseUrl}}"], "path": ["api", "federal", "master-data"] }
          }
        },
        {
          "name": "Federal Farmer Requests (All)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/federal/farmer-requests?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "federal", "farmer-requests"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        }
      ]
    },
    {
      "name": "03. Region Module",
      "item": [
        {
          "name": "Region Summary",
          "request": {
            "method": "GET",
