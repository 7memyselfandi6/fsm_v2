    {
      "name": "06. Warehouse System",
      "item": [
        {
          "name": "Get All Warehouses",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/warehouses?page=1&limit=10&q=Bahr Dar", "host": ["{{baseUrl}}"], "path": ["api", "warehouses"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }, { "key": "q", "value": "Bahr Dar" }] }
          }
        },
        {
          "name": "Create Warehouse",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"center\": \"Central Hub\",\n  \"destinationId\": \"DEST_UUID\",\n  \"regionId\": \"REGION_UUID\",\n  \"zoneId\": \"ZONE_UUID\",\n  \"woredaId\": \"WOREDA_UUID\",\n  \"town\": \"Addis\",\n  \"year\": 2026,\n  \"capacity\": 5000,\n  \"storeman\": \"Chala\",\n  \"sex\": \"MALE\",\n  \"education\": \"Degree\",\n  \"mobile\": \"0911000000\",\n  \"hasOffice\": true,\n  \"networkType\": \"4G\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/warehouses", "host": ["{{baseUrl}}"], "path": ["api", "warehouses"] }
          }
        },
        {
          "name": "Delete Warehouse",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/warehouses/UUID", "host": ["{{baseUrl}}"], "path": ["api", "warehouses", "UUID"] }
          }
        }
      ]
    },
