{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    
    // This allows TS to find @types/node, @types/express, etc.
    "types": ["node"], 

    // Output settings
    "sourceMap": true,
    "declaration": true,

    // Relaxed settings to ensure the build actually finishes
    "strict": false,
    "noImplicitAny": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma.config.ts", "scripts"]
}
