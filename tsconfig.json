{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    
    // We removed "types": [] to allow auto-discovery of node, express, etc.
    
    "sourceMap": true,
    "declaration": true,
    "strict": false,
    "noImplicitAny": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma.config.ts", "scripts"]
}
